{
  "name": "@triforge/physics-core",
  "version": "0.1.1",
  "description": "Blender-matched cloth simulation with Verlet integration, spring constraints, and colliders for Three.js",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node test/run-tests.js",
    "bench": "node bench/run-bench.js"
  },
  "keywords": [
    "cloth",
    "physics",
    "simulation",
    "verlet",
    "three.js",
    "blender"
  ],
  "license": "MIT",
  "peerDependencies": {
    "three": ">=0.128.0"
  },
  "devDependencies": {
    "@types/three": "^0.156.0",
    "three": "^0.156.0",
    "typescript": "^5.3.0"
  },
  "author": "Aftab Ibrahim Kazi",
  "repository": {
    "type": "git",
    "url": "https://github.com/AftabIbrahimKazi/triforge.git",
    "directory": "st-physics-core"
  },
  "homepage": "https://github.com/AftabIbrahimKazi/triforge#readme",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  }
