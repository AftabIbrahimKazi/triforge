  "license": "MIT",
  "peerDependencies": {
    "three": ">=0.128.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/three": "^0.156.0",
    "rollup": "^4.60.4",
    "three": "^0.156.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "conjugate-gradient": "^0.0.2"
  },
  "author": "Aftab Ibrahim Kazi",
  "repository": {
    "type": "git",
    "url": "https://github.com/AftabIbrahimKazi/triforge.git",
    "directory": "st-fluid-core"
  },
  "homepage": "https://github.com/AftabIbrahimKazi/triforge#readme",
